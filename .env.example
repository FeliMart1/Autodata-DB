# Servidor SQL Server
# Si usas Windows Authentication (recomendado para SQL Server Express):
# Deja DB_USER y DB_PASSWORD vacíos o comentados
DB_HOST=localhost
DB_DATABASE=Autodata
DB_INSTANCE=SQLEXPRESS

# Solo si usas SQL Server Authentication (usuario/contraseña):
# DB_USER=sa
# DB_PASSWORD=TuPassword
# DB_PORT=1433

# Puerto del servidor
PORT=3000

# JWT Secret
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion

# Entorno
NODE_ENV=development
